{
  "name": "@flowlm/desktop",
  "version": "0.1.0",
  "description": "FlowLM desktop application",
  "main": "./out/main/index.js",
  "author": "Sam",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.web.config.ts",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "electron-vite build && electron-builder"
  },
  "comment:dependencies": "All renderer deps are bundled into out/renderer by Vite; main/preload use only electron + node built-ins. The app ships zero runtime node_modules, so everything lives in devDependencies. This keeps `dependencies` empty, which makes electron-builder skip its production-dependency collection step (that step spawns app-builder-bin and fails under npm workspaces in CI).",
  "dependencies": {},
  "devDependencies": {
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.34.0",
    "@flowlm/core": "*",
    "@fontsource/inter": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.0",
    "@lezer/highlight": "^1.2.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@uiw/react-codemirror": "^4.23.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@xyflow/react": "^12.3.0",
    "electron": "33.4.11",
    "electron-builder": "^25.1.0",
    "electron-vite": "^2.3.0",
    "elkjs": "^0.11.1",
    "html-to-image": "^1.11.13",
    "mermaid": "^11.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
